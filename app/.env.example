# Copia questo file in ".env.local" e incolla i valori dal tuo progetto Supabase
# (Supabase Dashboard -> Project Settings -> API). NON committare ".env.local".
# Solo le variabili con prefisso VITE_ vengono esposte al frontend: la anon key
# e' pensata per stare nel client, e' protetta dalle Row Level Security policy del DB.

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
