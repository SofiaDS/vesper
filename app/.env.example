# Copia questo file in ".env.local" e incolla i valori dal tuo progetto Supabase
# (Supabase Dashboard -> Project Settings -> API). NON committare ".env.local".
# Solo le variabili con prefisso VITE_ vengono esposte al frontend: la anon key
# e' pensata per stare nel client, e' protetta dalle Row Level Security policy del DB.

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Chiave PUBBLICA VAPID per le notifiche Web Push (la coppia privata vive solo
# nelle edge function Supabase). Senza questa, il toggle "Notifiche push" nelle
# impostazioni non viene mostrato (vedi usePushNotifications.ts -> supported).
# IMPORTANTE: va impostata anche tra le Environment Variables di Vercel
# (Production/Preview), altrimenti il build deployato non la include.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
